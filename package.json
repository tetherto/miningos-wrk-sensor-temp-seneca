{
  "name": "@tetherto/miningos-wrk-sensor-temp-seneca",
  "version": "0.0.1",
  "description": "MiningOS Worker Sensor Temperature SENECA",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-wrk-sensor-temp-seneca.git"
  },
  "homepage": "https://github.com/tetherto/miningos-wrk-sensor-temp-seneca#readme",
  "bugs": {
    "url": "https://github.com/tetherto/miningos-wrk-sensor-temp-seneca/issues"
  },  
  "engines": {
    "node": ">=20"
  },
  "files": [
    "worker.js",
    "workers/",
    "mock/"
  ],
  "main": "worker.js",  
  "type": "commonjs",
  "bin": {
    "miningos-wrk-sensor-temp-seneca": "worker.js"
  },     
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "brittle tests/unit/*.js",
    "test:integration": "NODE_ENV=test brittle ./tests/sensor.test.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js",
    "dev": "node worker.js --wtype wrk-sensor-rack-temp-seneca --env development --rack rack-0",
    "mock": "node mock/server.js --type Seneca -p 5020 -h 0.0.0.0"
  },
  "dependencies": {
    "@bitfinex/bfx-svc-boot-js": "1.2.0",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "async": "3.2.6",
    "@tetherto/miningos-tpl-wrk-sensor": "git+https://github.com/tetherto/miningos-tpl-wrk-sensor.git",
    "@tetherto/svc-facs-modbus": "git+https://github.com/tetherto/svc-facs-modbus.git"
  },
  "devDependencies": {
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "brittle": "3.16.3",
    "debug": "4.4.1",
    "modbus-stream": "0.46.0",
    "@tetherto/miningos-mock-control-service": "git+https://github.com/tetherto/miningos-mock-control-service.git",
    "standard": "17.1.2",
    "uuid": "9.0.1",
    "yargs": "17.7.2"
  },
  "overrides": {
    "serialport": "npm:noop@1.0.0"
  }
}
